{
  "name": "WriterRefactorTool",
  "displayName": "WriterRefactorTool",
  "description": "Refactor-like name registration and rename for novel writing",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:plaintext",
    "onLanguage:markdown",
    "onCommand:writerRefactor.registerSelectedText",
    "onCommand:writerRefactor.unregisterSelectedText",
    "onCommand:writerRefactor.renameSelectedEntry",
    "onCommand:writerRefactor.openRegistry"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "writerRefactor.registerSelectedText",
        "title": "Writer Refactor: Register Selected Text"
      },
      {
        "command": "writerRefactor.unregisterSelectedText",
        "title": "Writer Refactor: Unregister Selected Text"
      },
      {
        "command": "writerRefactor.renameSelectedEntry",
        "title": "Writer Refactor: Rename Current Refactor Object"
      },
      {
        "command": "writerRefactor.openRegistry",
        "title": "Writer Refactor: Open Registry JSON"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "writerRefactor.registerSelectedText",
          "when": "editorTextFocus && writerRefactor.canRegister"
        },
        {
          "command": "writerRefactor.unregisterSelectedText",
          "when": "editorTextFocus && writerRefactor.canUnregister"
        },
        {
          "command": "writerRefactor.renameSelectedEntry",
          "when": "editorTextFocus && writerRefactor.canRename"
        }
      ]
    },
    "configuration": {
      "title": "Writer Refactor",
      "properties": {
        "writerRefactor.matchMode": {
          "type": "string",
          "enum": [
            "wholeWord",
            "substring"
          ],
          "default": "substring",
          "description": "Matching mode for rename operations."
        },
        "writerRefactor.registryPath": {
          "type": "string",
          "default": ".writer-refactor/registry.json",
          "description": "Path to registry JSON relative to workspace root."
        },
        "writerRefactor.excludeRules": {
          "type": "object",
          "default": {
            "excludeFencedCode": true,
            "excludeInlineCode": true,
            "customRegex": []
          },
          "properties": {
            "excludeFencedCode": {
              "type": "boolean",
              "default": true,
              "description": "Exclude markdown fenced code blocks from rename."
            },
            "excludeInlineCode": {
              "type": "boolean",
              "default": true,
              "description": "Exclude markdown inline code from rename."
            },
            "customRegex": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Custom regex rules that define excluded ranges."
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
