{
  "name": "WriterRefactorTool",
  "displayName": "WriterRefactorTool",
  "description": "Refactor-like name registration and rename for novel writing",
  "version": "0.0.1",
  "publisher": "magic-gcy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/WriterRefactorTool.git"
  },
  "homepage": "https://github.com/your-username/WriterRefactorTool#readme",
  "bugs": {
    "url": "https://github.com/your-username/WriterRefactorTool/issues"
  },
  "keywords": [
    "vscode",
    "extension",
    "writing",
    "refactor",
    "alias",
    "character"
  ],
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:plaintext",
    "onLanguage:markdown",
    "onCommand:writerRefactor.registerSelectedRole",
    "onCommand:writerRefactor.registerSelectedAlias",
    "onCommand:writerRefactor.unregisterSelectedAlias",
    "onCommand:writerRefactor.unregisterSelectedCharacter",
    "onCommand:writerRefactor.renameSelectedEntry",
    "onCommand:writerRefactor.openRegistry",
    "onCommand:writerRefactor.openCharacterManager"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "writerRefactor.registerSelectedRole",
        "title": "Writer Refactor: 注册角色"
      },
      {
        "command": "writerRefactor.registerSelectedAlias",
        "title": "Writer Refactor: 注册别名"
      },
      {
        "command": "writerRefactor.unregisterSelectedAlias",
        "title": "Writer Refactor: 取消注册别名"
      },
      {
        "command": "writerRefactor.unregisterSelectedCharacter",
        "title": "Writer Refactor: 取消注册角色"
      },
      {
        "command": "writerRefactor.renameSelectedEntry",
        "title": "Writer Refactor: 重命名当前对象"
      },
      {
        "command": "writerRefactor.openRegistry",
        "title": "Writer Refactor: 打开注册表 JSON"
      },
      {
        "command": "writerRefactor.openCharacterManager",
        "title": "Writer Refactor: 打开角色管理面板"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "writerRefactor.registerSelectedRole",
          "when": "editorTextFocus && writerRefactor.canRegister"
        },
        {
          "command": "writerRefactor.registerSelectedAlias",
          "when": "editorTextFocus && writerRefactor.canRegisterAlias"
        },
        {
          "command": "writerRefactor.unregisterSelectedAlias",
          "when": "editorTextFocus && writerRefactor.canUnregisterAlias"
        },
        {
          "command": "writerRefactor.unregisterSelectedCharacter",
          "when": "editorTextFocus && writerRefactor.canUnregisterCharacter"
        },
        {
          "command": "writerRefactor.renameSelectedEntry",
          "when": "editorTextFocus && writerRefactor.canRename"
        }
      ]
    },
    "configuration": {
      "title": "Writer Refactor",
      "properties": {
        "writerRefactor.matchMode": {
          "type": "string",
          "enum": [
            "wholeWord",
            "substring"
          ],
          "default": "substring",
          "description": "Matching mode for rename operations."
        },
        "writerRefactor.registryPath": {
          "type": "string",
          "default": "registry.json",
          "description": "Path to registry JSON relative to extension private storage."
        },
        "writerRefactor.excludeRules": {
          "type": "object",
          "default": {
            "excludeFencedCode": true,
            "excludeInlineCode": true,
            "customRegex": []
          },
          "properties": {
            "excludeFencedCode": {
              "type": "boolean",
              "default": true,
              "description": "Exclude markdown fenced code blocks from rename."
            },
            "excludeInlineCode": {
              "type": "boolean",
              "default": true,
              "description": "Exclude markdown inline code from rename."
            },
            "customRegex": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Custom regex rules that define excluded ranges."
            }
          }
        },
        "writerRefactor.highlightColors": {
          "type": "object",
          "default": {
            "strong": {
              "color": "theme:editorWarning.foreground",
              "backgroundColor": "theme:editor.wordHighlightBackground",
              "borderColor": "theme:editor.wordHighlightStrongBorder",
              "overviewRulerColor": "theme:editor.findMatchHighlightBackground"
            },
            "weak": {
              "color": "theme:editor.foreground",
              "backgroundColor": "theme:editor.wordHighlightTextBackground",
              "borderColor": "theme:editor.wordHighlightBorder",
              "overviewRulerColor": "theme:editor.wordHighlightTextBackground"
            }
          },
          "description": "Highlight color settings. Supports plain colors like #RRGGBB or theme tokens with prefix theme: (for example theme:editor.wordHighlightBackground).",
          "properties": {
            "strong": {
              "type": "object",
              "properties": {
                "color": {
                  "type": "string",
                  "default": "theme:editorWarning.foreground"
                },
                "backgroundColor": {
                  "type": "string",
                  "default": "theme:editor.wordHighlightBackground"
                },
                "borderColor": {
                  "type": "string",
                  "default": "theme:editor.wordHighlightStrongBorder"
                },
                "overviewRulerColor": {
                  "type": "string",
                  "default": "theme:editor.findMatchHighlightBackground"
                }
              }
            },
            "weak": {
              "type": "object",
              "properties": {
                "color": {
                  "type": "string",
                  "default": "theme:editor.foreground"
                },
                "backgroundColor": {
                  "type": "string",
                  "default": "theme:editor.wordHighlightTextBackground"
                },
                "borderColor": {
                  "type": "string",
                  "default": "theme:editor.wordHighlightBorder"
                },
                "overviewRulerColor": {
                  "type": "string",
                  "default": "theme:editor.wordHighlightTextBackground"
                }
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.106.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
